#!/bin/bash
#
# Ghostty Launcher v0.1.0 — Per-project dock terminals
#
# Usage: launcher [OPTIONS] <project-dir>
#
set -euo pipefail

readonly VERSION="0.1.0"
# Ghostty binary lookup chain: explicit env var → stock Ghostty
if [[ -n "${GHOSTTY_BINARY_PATH:-}" ]] && [[ -d "$GHOSTTY_BINARY_PATH" ]]; then
	readonly GHOSTTY_APP="$GHOSTTY_BINARY_PATH"
	readonly GHOSTTY_SOURCE="GHOSTTY_BINARY_PATH"
else
	readonly GHOSTTY_APP="/Applications/Ghostty.app"
	readonly GHOSTTY_SOURCE="stock"
fi

# Validate GHOSTTY_APP is actually a Ghostty bundle by checking CFBundleIdentifier.
# Warns but does not hard-fail — a legitimately modified bundle should still work.
_ghostty_plist="${GHOSTTY_APP}/Contents/Info.plist"
if [[ ! -f "$_ghostty_plist" ]]; then
	echo "Warning: Ghostty bundle validation failed: Info.plist not found in ${GHOSTTY_APP}" >&2
else
	_ghostty_bid=$(/usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$_ghostty_plist" 2>/dev/null || true)
	_ghostty_bid_lower=$(echo "$_ghostty_bid" | LC_ALL=C tr '[:upper:]' '[:lower:]')
	if [[ "$_ghostty_bid_lower" != *ghostty* ]]; then
		echo "Warning: Bundle at ${GHOSTTY_APP} may not be Ghostty (CFBundleIdentifier: '${_ghostty_bid}')" >&2
	fi
	unset _ghostty_bid _ghostty_bid_lower
fi
unset _ghostty_plist

readonly PROJECTS_DIR="/Applications/Projects"

# ── Settings parsing ──────────────────────────────────────────────────

# Infer icon from project directory basename keywords.
# Returns a single emoji or empty string if no keyword matches.
_icon_from_name() {
	local slug="$1"
	case "$slug" in
		# Infra / containers — must precede *doc* to avoid matching "docker"
		*docker* | *k8s* | *kubernetes* | *terraform* | *infra* | *deploy* | *helm* | *ansible*)
			echo "🏗️"
			;;
		*docs* | *documentation* | *wiki* | *book* | *manual* | *guide*)
			echo "📚"
			;;
		*dashboard* | *admin* | *monitor* | *status* | *analytics*)
			echo "📊"
			;;
		*api* | *server* | *backend* | *service* | *gateway*)
			echo "⚙️"
			;;
		*cli* | *tool* | *launcher* | *utility*)
			echo "🛠️"
			;;
		*config* | *dotfile*)
			echo "🔧"
			;;
		*mobile* | *ios* | *android* | *flutter* | *react-native*)
			echo "📱"
			;;
		*web* | *frontend* | *site* | *www*)
			echo "🌐"
			;;
		*test* | *spec* | *qa* | *e2e*)
			echo "🧪"
			;;
		*data* | *pipeline* | *etl*)
			echo "🧠"
			;;
		*game* | *engine* | *unity* | *godot*)
			echo "🎮"
			;;
		*bot* | *chat*)
			echo "🤖"
			;;
		*lib* | *sdk* | *package* | *framework* | *plugin*)
			echo "📦"
			;;
		*design* | *figma* | *sketch*)
			echo "🎨"
			;;
		*auth* | *security* | *crypto*)
			echo "🔒"
			;;
	esac
}

# Infer icon from well-known top-level files or directories.
# Returns a single emoji or empty string if nothing recognized.
_icon_from_files() {
	local dir="$1"
	if [[ -f "$dir/Dockerfile" ]] || [[ -f "$dir/docker-compose.yml" ]] || [[ -f "$dir/docker-compose.yaml" ]]; then
		echo "🐳"
	elif [[ -f "$dir/Cargo.toml" ]]; then
		echo "🦀"
	elif [[ -f "$dir/requirements.txt" ]] || [[ -f "$dir/pyproject.toml" ]] || [[ -f "$dir/setup.py" ]]; then
		echo "🐍"
	elif [[ -f "$dir/Gemfile" ]]; then
		echo "💎"
	elif [[ -f "$dir/package.json" ]]; then
		echo "📦"
	elif [[ -f "$dir/go.mod" ]]; then
		echo "🔷"
	elif [[ -f "$dir/mix.exs" ]]; then
		echo "💧"
	elif [[ -f "$dir/build.gradle" ]] || [[ -f "$dir/pom.xml" ]]; then
		echo "☕"
	elif [[ -d "$dir/.github" ]]; then
		echo "🐙"
	elif [[ -f "$dir/index.html" ]]; then
		echo "🌐"
	fi
}

# Resolve project icon via deterministic fallback chain:
#   1. Explicit .vscode/settings.json icon
#   2. Project directory name heuristics
#   3. Top-level file / folder heuristics
#   4. Default fallback (📁)
parse_icon() {
	local dir="$1"
	local icon=""

	# 1. Explicit settings.json icon (highest priority)
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		icon=$(jq -r '."commandCentral.project.icon" // empty' "$settings" 2>/dev/null || true)
	fi
	if [[ -n "$icon" ]]; then
		echo "$icon"
		return
	fi

	# 2. Project name / folder slug heuristics
	local slug
	slug=$(basename "$dir" | LC_ALL=C tr '[:upper:]' '[:lower:]')
	icon=$(_icon_from_name "$slug")
	if [[ -n "$icon" ]]; then
		echo "$icon"
		return
	fi

	# 3. Top-level file / folder heuristics (cheap stat checks only)
	icon=$(_icon_from_files "$dir")
	if [[ -n "$icon" ]]; then
		echo "$icon"
		return
	fi

	# 4. Default fallback
	echo "📁"
}

# Parse commandCentral.terminal.backgroundImage.enabled from .vscode/settings.json
parse_background() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		jq -r '."commandCentral.terminal.backgroundImage.enabled" // empty' "$settings" 2>/dev/null || true
	fi
}

# Parse commandCentral.terminal.backgroundImage.opacity from .vscode/settings.json
parse_background_opacity() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		jq -r '."commandCentral.terminal.backgroundImage.opacity" // empty' "$settings" 2>/dev/null || true
	fi
}

# Parse commandCentral.terminal.backgroundImage.position from .vscode/settings.json
parse_background_position() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		jq -r '."commandCentral.terminal.backgroundImage.position" // empty' "$settings" 2>/dev/null || true
	fi
}

# Parse commandCentral.terminal.backgroundImage.fit from .vscode/settings.json
parse_background_fit() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		jq -r '."commandCentral.terminal.backgroundImage.fit" // empty' "$settings" 2>/dev/null || true
	fi
}

# Parse commandCentral.terminal.multiplexer from .vscode/settings.json
# Returns "tmux", "zellij", or empty (caller picks default)
parse_multiplexer() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	if [[ -f "$settings" ]]; then
		jq -r '."commandCentral.terminal.multiplexer" // empty' "$settings" 2>/dev/null || true
	fi
}

# Locate the config repo's zellij baseline directory.
# Returns the parent of zellij/ (so caller does $repo/zellij/config.kdl).
# Empty string if no candidate is found — caller should fall back to a
# minimal embedded default.
find_zellij_baseline_repo() {
	local candidate
	for candidate in "${GHL_CONFIG_REPO:-}" "${HOME}/projects/config" "${HOME}/.config"; do
		if [[ -n "$candidate" ]] && [[ -f "$candidate/zellij/config.kdl" ]]; then
			echo "$candidate"
			return 0
		fi
	done
	return 1
}

# Parse commandCentral.project.name from .vscode/settings.json
# Falls back to directory basename
parse_name() {
	local dir="$1"
	local settings="$dir/.vscode/settings.json"
	local name=""
	if [[ -f "$settings" ]]; then
		name=$(jq -r '."commandCentral.project.name" // empty' "$settings" 2>/dev/null || true)
	fi
	if [[ -z "$name" ]]; then
		name=$(basename "$dir")
	fi
	echo "$name"
}

# ── Sanitization ─────────────────────────────────────────────────────

# Sanitize name for bundle ID (lowercase, alphanum + hyphens only)
sanitize_for_bundle() {
	local name="$1"
	local result
	# Single pipeline: lowercase, spaces/slashes→hyphens, strip non-alnum, collapse hyphens, trim
	# Force C locale so [:alnum:] matches only ASCII a-z, A-Z, 0-9 regardless of system locale
	result=$(echo "$name" | LC_ALL=C tr '[:upper:]' '[:lower:]' | LC_ALL=C sed 's/[[:space:]\/]/-/g' | LC_ALL=C tr -cd '[:alnum:]-' | LC_ALL=C sed -E 's/-+/-/g; s/^-+//; s/-+$//')
	# Ensure result doesn't start with a digit (bundle IDs must begin with a letter)
	if [[ "$result" =~ ^[0-9] ]]; then
		result="project-${result}"
	fi
	echo "$result"
}

# Generate emoji background PNG for terminal watermark
# Uses the same sips + Canvas approach as icon generation but at larger size
generate_emoji_background() {
	local emoji="$1"
	local output_path="$2"
	local max_width="${3:-300}"
	local temp_dir
	temp_dir=$(mktemp -d)

	local escaped_emoji
	# shellcheck disable=SC1003
	escaped_emoji=$(printf '%s' "$emoji" | sed 's/\\/\\\\/g; s/'"'"'/\\'"'"'/g; s/"/\\"/g')

	cat >"$temp_dir/render_bg.js" <<EOF
const canvas = new Canvas(${max_width}, ${max_width})
const ctx = canvas.getContext('2d')
ctx.fillStyle = 'rgba(0, 0, 0, 0)'
ctx.fillRect(0, 0, ${max_width}, ${max_width})
const targetFill = ${max_width} * 0.75
const baseGlyphSize = 16
const scale = targetFill / baseGlyphSize
ctx.save()
ctx.fillStyle = 'black'
ctx.translate(${max_width} / 2, ${max_width} / 2)
ctx.scale(scale, scale)
ctx.textAlign = 'center'
ctx.textBaseline = 'middle'
ctx.fillText('${escaped_emoji}', 0, -1.5)
ctx.restore()
const output = new Output(canvas, sips.outputPath)
output.addToQueue()
EOF

	if ! sips -j "$temp_dir/render_bg.js" -o "$output_path" >/dev/null 2>&1; then
		echo "Warning: Could not generate background PNG for $emoji" >&2
		rm -rf "$temp_dir"
		return 1
	fi

	rm -rf "$temp_dir"
	return 0
}

# ── PATH detection ──────────────────────────────────────────────────
# (Removed: detect_homebrew_path / build_tool_path)
# PATH is no longer baked at bundle creation time. The generated
# launch-tmux.sh starts $SHELL -l inside tmux, which rebuilds PATH from
# /etc/paths, /etc/paths.d/*, and user init files at launch time.

# ── Validation ───────────────────────────────────────────────────────

# Reject paths containing shell-dangerous characters
validate_path_safe() {
	local path="$1"
	case "$path" in
		*';'* | *'&'* | *'|'* | *'`'* | *'$'*)
			echo "Error: Project path contains shell-unsafe characters" >&2
			return 1
			;;
	esac
}

# ── Icon generation ──────────────────────────────────────────────────

# Check if input is an emoji
is_emoji() {
	local input="$1"
	echo "$input" | perl -CS -ne 'print if /[\x{2190}-\x{21FF}]|[\x{2300}-\x{27BF}]|[\x{2B00}-\x{2BFF}]|[\x{1F300}-\x{1F9FF}]|[\x{1F680}-\x{1F6FF}]|[\x{1F900}-\x{1F9FF}]/' | perl -CS -pe 's/[\x{FE0E}\x{FE0F}]//g'
}

# Generate .icns from emoji using sips + iconutil
generate_emoji_icns() {
	local emoji="$1"
	local output_path="$2"
	local temp_dir
	temp_dir=$(mktemp -d)

	local iconset_dir="$temp_dir/icon.iconset"
	mkdir -p "$iconset_dir"

	# Apple requires exactly these 10 sizes for a complete .iconset
	local sizes=(
		"16:icon_16x16.png"
		"32:icon_32x32.png"
		"64:icon_32x32@2x.png"
		"32:icon_16x16@2x.png"
		"128:icon_128x128.png"
		"256:icon_256x256.png"
		"256:icon_128x128@2x.png"
		"512:icon_512x512.png"
		"512:icon_256x256@2x.png"
		"1024:icon_512x512@2x.png"
	)

	local escaped_emoji
	# shellcheck disable=SC1003
	escaped_emoji=$(printf '%s' "$emoji" | sed 's/\\/\\\\/g; s/'"'"'/\\'"'"'/g; s/"/\\"/g')

	for size_spec in "${sizes[@]}"; do
		IFS=':' read -r pixels filename <<<"$size_spec"

		cat >"$temp_dir/render_${pixels}.js" <<EOF
const canvas = new Canvas(${pixels}, ${pixels})
const ctx = canvas.getContext('2d')
ctx.fillStyle = 'rgba(0, 0, 0, 0)'
ctx.fillRect(0, 0, ${pixels}, ${pixels})
const targetFill = ${pixels} * 0.8
const baseGlyphSize = 16
const scale = targetFill / baseGlyphSize
ctx.save()
ctx.fillStyle = 'black'
ctx.translate(${pixels} / 2, ${pixels} / 2)
ctx.scale(scale, scale)
ctx.textAlign = 'center'
ctx.textBaseline = 'middle'
ctx.fillText('${escaped_emoji}', 0, -1.5)
ctx.restore()
const output = new Output(canvas, sips.outputPath)
output.addToQueue()
EOF

		if ! sips -j "$temp_dir/render_${pixels}.js" -o "$iconset_dir/$filename" >/dev/null 2>&1; then
			rm -rf "$temp_dir"
			return 1
		fi
	done

	if ! iconutil -c icns "$iconset_dir" -o "$output_path" 2>/dev/null; then
		rm -rf "$temp_dir"
		return 1
	fi

	rm -rf "$temp_dir"
	return 0
}

# Generate icon — emoji if available, else system fallback
generate_icon() {
	local emoji="$1"
	local output_path="$2"

	if [[ -n "$emoji" ]] && [[ -n "$(is_emoji "$emoji")" ]]; then
		if generate_emoji_icns "$emoji" "$output_path"; then
			return 0
		fi
	fi

	# Fallback: copy Ghostty's own icon
	if ! cp "${GHOSTTY_APP}/Contents/Resources/Ghostty.icns" "$output_path" 2>/dev/null; then
		echo "Error: Failed to generate icon and fallback copy failed" >&2
		return 1
	fi
}

# ── Bundle creation ──────────────────────────────────────────────────

# Create a clean .app bundle with only Ghostty binary and custom icon
create_bundle() {
	local project_dir="$1"
	local name="$2"
	local icon="$3"
	local output_dir="${4:-$PROJECTS_DIR}"

	# Validate inputs
	if [[ ! -d "$project_dir" ]]; then
		echo "Error: Project directory does not exist: $project_dir" >&2
		return 1
	fi

	local project_path_length=${#project_dir}
	if [[ $project_path_length -ge 1000 ]]; then
		echo "Error: Project path too long ($project_path_length chars, max 999)" >&2
		return 1
	fi

	# Reject paths with shell-dangerous characters
	if ! validate_path_safe "$project_dir"; then
		return 1
	fi

	if [[ -z "$name" ]]; then
		echo "Error: Project name cannot be empty" >&2
		return 1
	fi

	local safe_name
	safe_name=$(sanitize_for_bundle "$name")

	if [[ -z "$safe_name" ]]; then
		echo "Error: Project name produces empty bundle identifier" >&2
		return 1
	fi

	local bundle_id="dev.partnerai.ghostty.${safe_name}"
	# Use safe_name (dashed) for filesystem path — spaces break Ghostty's command= parser
	# The display name (CFBundleName/CFBundleDisplayName) stays human-readable
	local app_path="${output_dir}/${safe_name}.app"
	local contents="${app_path}/Contents"

	# Path traversal prevention: verify bundle stays within output_dir
	if [[ "$app_path" == *../* ]]; then
		echo "Error: Bundle path escapes output directory" >&2
		return 1
	fi

	# File locking: prevent concurrent runs for same project (using mkdir for atomicity)
	local lock_dir="/tmp/.ghostty-launcher-${safe_name}.lock"

	# Stale lock detection: remove locks older than 1 hour
	if [[ -d "$lock_dir" ]]; then
		local lock_age
		lock_age=$(($(date +%s) - $(stat -f %m "$lock_dir")))
		if [[ $lock_age -gt 3600 ]]; then
			echo "Warning: Removing stale lock for project '$name' (${lock_age}s old)" >&2
			rmdir "$lock_dir" 2>/dev/null || true
		else
			echo "Error: Another launcher is already running for project: $name" >&2
			return 1
		fi
	fi

	if ! mkdir "$lock_dir" 2>/dev/null; then
		echo "Error: Another launcher is already running for project: $name" >&2
		return 1
	fi

	# Single compound cleanup — set once, variables updated as resources are acquired
	_launcher_lock_dir="$lock_dir"
	_launcher_temp_dir=""
	cleanup_launcher() {
		[[ -n "$_launcher_temp_dir" ]] && rm -rf "$_launcher_temp_dir"
		[[ -n "$_launcher_lock_dir" ]] && rmdir "$_launcher_lock_dir" 2>/dev/null || true
	}
	trap cleanup_launcher EXIT

	# Check if source Ghostty binary exists
	local ghostty_binary="${GHOSTTY_APP}/Contents/MacOS/ghostty"
	if [[ ! -f "$ghostty_binary" ]]; then
		echo "Error: Ghostty binary not found at $ghostty_binary" >&2
		return 1
	fi

	echo "Creating project bundle ${name}.app..." >&2
	echo "  Ghostty source: ${GHOSTTY_APP} (${GHOSTTY_SOURCE})" >&2

	# Atomic bundle creation: build in temp directory, rename on success
	local temp_dir
	temp_dir=$(mktemp -d)
	_launcher_temp_dir="$temp_dir"

	# Keep the temp bundle path aligned with the sanitized final path so
	# display names containing traversal characters cannot escape temp_dir.
	local temp_app_path="${temp_dir}/${safe_name}.app"
	local temp_contents="${temp_app_path}/Contents"
	local temp_resources="${temp_contents}/Resources"

	# Use ditto to copy Ghostty.app (APFS clone — nearly free on same volume)
	if ! ditto "$GHOSTTY_APP" "$temp_app_path"; then
		echo "Error: Failed to copy Ghostty.app bundle" >&2
		return 1
	fi

	# Remove Asset Catalog (contains Ghostty's icon, overrides our .icns)
	rm -f "${temp_resources}/Assets.car"

	# Replace icon with project emoji icon
	rm -f "${temp_resources}/Ghostty.icns"
	if ! generate_icon "$icon" "${temp_resources}/icon.icns"; then
		echo "Error: Failed to generate icon for project" >&2
		return 1
	fi

	# Create per-project Ghostty config directory
	# This gives each project its own config, preventing window merging
	local config_dir="${temp_contents}/Resources/ghostty-config/ghostty"
	mkdir -p "$config_dir"

	local session_id="agent-${safe_name}"

	# ── Multiplexer selection ─────────────────────────────────────
	# Precedence: --multiplexer CLI flag > .vscode/settings.json
	#           > GHL_DEFAULT_MULTIPLEXER env > "zellij" baseline.
	local multiplexer
	multiplexer=$(parse_multiplexer "$project_dir")
	multiplexer="${MULTIPLEXER_OVERRIDE:-${multiplexer:-${GHL_DEFAULT_MULTIPLEXER:-zellij}}}"
	case "$multiplexer" in
		tmux | zellij) ;;
		*)
			echo "Error: unknown multiplexer '$multiplexer' (expected: tmux, zellij)" >&2
			return 1
			;;
	esac
	echo "  Multiplexer: ${multiplexer}" >&2

	# Copy user's base ghostty config, stripping shell/command settings that
	# conflict with the bundle launcher. Both multiplexer branches need this.
	if [[ -f "${HOME}/.config/ghostty/config" ]]; then
		grep -v -E '^(command|shell-integration)\s*=' "${HOME}/.config/ghostty/config" >"$config_dir/config" || true
	else
		touch "$config_dir/config"
	fi

	if [[ "$multiplexer" == "tmux" ]]; then
		cat >"${config_dir}/tmux.conf" <<'TMUX_CONF'
set -g status on
set -g status-position bottom
set -g status-interval 2
set -g mouse on
set -g history-limit 50000
set -g allow-passthrough on
set -g automatic-rename off
set -g allow-rename off
set -g renumber-windows on
set -g base-index 1
set -g status-left " #{session_name} "
set -g status-right " F2/F3 switch | F8 detach "
bind -n F2 previous-window
bind -n F3 next-window
bind -n F8 detach-client
TMUX_CONF

		# Create tmux launch script inside the bundle
		cat >"${config_dir}/launch-tmux.sh" <<LAUNCH
#!/bin/bash
PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
SCRIPT_DIR="\$(cd "\$(dirname "\$0")" && pwd)"

# Validate project directory exists
PROJECT_DIR="${project_dir}"
if [[ ! -d "\$PROJECT_DIR" ]]; then
  echo "Error: Project directory no longer exists: \$PROJECT_DIR" >&2
  echo "The directory may have been moved or deleted after bundle creation." >&2
  echo "Please recreate the bundle if the directory has moved to a new location." >&2
  exit 1
fi

SESSION_ID="\${GHOSTTY_SESSION_ID:-${session_id}}"
SOCKET_DIR="\${XDG_STATE_HOME:-\$HOME/.local/state}/ghostty-launcher/tmux"
runtime_slug="\${SESSION_ID#agent-}"
if (( \${#runtime_slug} > 32 )); then
  runtime_slug="\${runtime_slug:0:32}-\$(printf '%s' "\$runtime_slug" | cksum | awk '{print \$1}')"
fi
TMUX_SOCKET="\${GHOSTTY_TMUX_SOCKET:-\${SOCKET_DIR}/\${runtime_slug}.sock}"
TMUX_CONF="\${GHOSTTY_TMUX_CONF:-\${SCRIPT_DIR}/tmux.conf}"

if ! command -v tmux >/dev/null 2>&1; then
  echo "Error: tmux is required. Install with: brew install tmux" >&2
  exec "\${SHELL:-/bin/zsh}" -l
fi

mkdir -p "\$SOCKET_DIR"
tmux_cmd=(tmux -f "\$TMUX_CONF" -S "\$TMUX_SOCKET")

# Clean stale socket files before bootstrap.
if [[ -e "\$TMUX_SOCKET" ]] && ! "\${tmux_cmd[@]}" list-sessions >/dev/null 2>&1; then
  rm -f "\$TMUX_SOCKET"
fi

# If session already exists, attach to it
if "\${tmux_cmd[@]}" has-session -t "\$SESSION_ID" 2>/dev/null; then
  exec "\${tmux_cmd[@]}" attach-session -t "\$SESSION_ID"
fi

# Create new session in project dir with login shell, then attach.
# If another launcher instance wins the race, fall back to attach.
if ! "\${tmux_cmd[@]}" new-session -d -s "\$SESSION_ID" -c "\$PROJECT_DIR" /bin/bash -l 2>/dev/null; then
  if "\${tmux_cmd[@]}" has-session -t "\$SESSION_ID" 2>/dev/null; then
    exec "\${tmux_cmd[@]}" attach-session -t "\$SESSION_ID"
  fi
  echo "Error: tmux failed to create session '\$SESSION_ID'" >&2
  exit 1
fi

exec "\${tmux_cmd[@]}" attach-session -t "\$SESSION_ID"
LAUNCH
		chmod +x "${config_dir}/launch-tmux.sh"
	else
		# ── Zellij branch ─────────────────────────────────────────
		# Bundle structure:
		#   ghostty-config/ghostty/launch-zellij.sh         (the launch script)
		#   ghostty-config/ghostty/zellij/layout.kdl        (per-project layout)
		#   ghostty-config/ghostty/zellij/config.kdl        (embedded baseline)
		#   ghostty-config/ghostty/zellij/themes/*.kdl      (embedded themes)
		mkdir -p "${config_dir}/zellij/themes"

		# IMPORTANT: zellij does NOT expand environment variables in layout files.
		# Resolve $SHELL at bundle-create time and bake the literal path into the
		# layout, otherwise zellij would try to execvp("${SHELL:-/bin/zsh}").
		local user_shell="${SHELL:-/bin/zsh}"
		if [[ ! -x "$user_shell" ]]; then
			user_shell="/bin/zsh"
		fi

		# Embed the per-project layout. KDL `command` is a pane attribute, NOT
		# a child node — `pane command="X" { args ... }` is correct.
		cat >"${config_dir}/zellij/layout.kdl" <<KDL
// layout.kdl — generated per-project layout for ${name}
//
// Bottom bar uses zellij:compact-bar (single line, hides keybind hints by
// default) instead of the default zellij:status-bar (two-line, always shows
// keybind hints + QuickNav). Saves a row of vertical space and reduces noise.
layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    tab name="main" focus=true {
        pane command="${user_shell}" {
            args "-l"
        }
    }

    tab name="logs" {
        pane split_direction="horizontal" {
            pane name="git log" command="git" {
                args "log" "--oneline" "--decorate" "--all" "--graph" "-n" "30"
            }
            pane name="status" command="${user_shell}" {
                args "-l"
            }
        }
    }
}
KDL

		# Embed a snapshot of the user's zellij baseline from the config repo,
		# or fall back to a minimal default if the repo is not available.
		local zellij_repo
		if zellij_repo=$(find_zellij_baseline_repo); then
			cp "${zellij_repo}/zellij/config.kdl" "${config_dir}/zellij/config.kdl"
			if [[ -d "${zellij_repo}/zellij/themes" ]]; then
				cp -R "${zellij_repo}/zellij/themes/." "${config_dir}/zellij/themes/" 2>/dev/null || true
			fi
			echo "  Zellij baseline: copied from ${zellij_repo}/zellij" >&2
		else
			cat >"${config_dir}/zellij/config.kdl" <<'ZELLIJ_FALLBACK'
// Minimal embedded fallback (config repo not found at bundle-create time)
mouse_mode true
default_mode "normal"
copy_on_select true
show_startup_tips false
pane_frames false
ZELLIJ_FALLBACK
			echo "  Zellij baseline: minimal embedded fallback (no config repo found)" >&2
		fi

		# Create zellij launch script inside the bundle
		cat >"${config_dir}/launch-zellij.sh" <<LAUNCH
#!/bin/bash
PATH="/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin"
SCRIPT_DIR="\$(cd "\$(dirname "\$0")" && pwd)"

# Validate project directory exists
PROJECT_DIR="${project_dir}"
if [[ ! -d "\$PROJECT_DIR" ]]; then
  echo "Error: Project directory no longer exists: \$PROJECT_DIR" >&2
  echo "The directory may have been moved or deleted after bundle creation." >&2
  exit 1
fi

SESSION_ID="\${GHOSTTY_SESSION_ID:-${session_id}}"
LAYOUT_PATH="\$SCRIPT_DIR/zellij/layout.kdl"

# ZELLIJ_CONFIG_DIR points at the bundle's embedded snapshot — never at
# ~/.config/zellij. Bundles are fully self-contained.
# ZELLIJ_SOCKET_DIR is the only real zellij isolation knob; per-bundle
# value gives socket-level isolation between projects.
# (ZELLIJ_CACHE_DIR and ZELLIJ_RUNTIME_DIR are NOT real zellij env vars.)
export ZELLIJ_CONFIG_DIR="\$SCRIPT_DIR/zellij"
export ZELLIJ_SOCKET_DIR="\${XDG_STATE_HOME:-\$HOME/.local/state}/ghostty-launcher/zellij/${safe_name}"
mkdir -p "\$ZELLIJ_SOCKET_DIR"

# Zellij freezes env vars at session-create time. GHOSTTY_BUNDLE_ID is set
# by Info.plist LSEnvironment when Ghostty launches us; explicit export
# documents the contract for child shells (Claude Code, etc.).
export GHOSTTY_BUNDLE_ID="\${GHOSTTY_BUNDLE_ID:-${bundle_id}}"

if ! command -v zellij >/dev/null 2>&1; then
  echo "Error: zellij is required. Install with: brew install zellij" >&2
  echo "Falling back to plain shell." >&2
  cd "\$PROJECT_DIR" || true
  exec "\${SHELL:-/bin/zsh}" -l
fi

# Idempotent attach: parse list-sessions, strip both [Created Xh ago] and
# (current)/(EXITED) annotations, exact-match on session name.
existing=\$(zellij list-sessions --no-formatting 2>/dev/null | sed -E 's/[[:space:]]*[[(].*\$//' | awk '{print \$1}')
if printf '%s\n' "\$existing" | grep -qx "\$SESSION_ID"; then
  exec zellij attach "\$SESSION_ID"
fi

cd "\$PROJECT_DIR" || exit 1
# Use --new-session-with-layout (-n) to CREATE a new session with the layout.
# The bare --session NAME --layout LAYOUT form is interpreted as "attach to existing
# session and add layout as a new tab" — fails with "There is no active session!" on
# first launch. The -n form is the canonical "create new session with layout" command.
exec zellij -n "\$LAYOUT_PATH" --session "\$SESSION_ID"
LAUNCH
		chmod +x "${config_dir}/launch-zellij.sh"
	fi

	# Append project-specific settings
	cat >>"$config_dir/config" <<CONF

# --- Project: ${name} ---
working-directory = ${project_dir}
title = ${name}
command = ${contents}/Resources/ghostty-config/ghostty/launch-${multiplexer}.sh

# --- Notifications ---
# Bell triggers Dock bounce + badge + macOS notification
# Agents use BEL + OSC 9 on completion for clickable notifications
desktop-notifications = true
CONF

	# Background image: render the project emoji as a scaled-up terminal watermark
	# Reads optional settings from .vscode/settings.json
	local bg_enabled bg_opacity bg_position bg_fit bg_max_width
	bg_enabled=$(parse_background "$project_dir")
	bg_opacity=$(parse_background_opacity "$project_dir")
	bg_position=$(parse_background_position "$project_dir")
	bg_fit=$(parse_background_fit "$project_dir")

	# Default: enabled unless explicitly set to "false"
	bg_enabled="${bg_enabled:-true}"
	bg_opacity="${bg_opacity:-0.07}"
	bg_position="${bg_position:-top-right}"
	bg_fit="${bg_fit:-none}"
	bg_max_width="300"

	if [[ "$bg_enabled" != "false" ]] && [[ -n "$icon" ]] && [[ -n "$(is_emoji "$icon")" ]]; then
		local bg_dest="${config_dir}/background.png"
		if generate_emoji_background "$icon" "$bg_dest" "$bg_max_width"; then
			cat >>"$config_dir/config" <<BG_CONF

# --- Background Image (emoji watermark) ---
background-image = ${contents}/Resources/ghostty-config/ghostty/background.png
background-image-opacity = ${bg_opacity}
background-image-position = ${bg_position}
background-image-fit = ${bg_fit}
BG_CONF
			echo "  Background: $icon (${bg_max_width}px, opacity ${bg_opacity}, ${bg_position})" >&2
		fi
	fi

	# Modify Info.plist — change identity, icon, add env vars
	local plist="${temp_contents}/Info.plist"
	/usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier ${bundle_id}" "$plist"
	/usr/libexec/PlistBuddy -c "Set :CFBundleName ${name}" "$plist"
	/usr/libexec/PlistBuddy -c "Set :CFBundleDisplayName ${name}" "$plist"
	/usr/libexec/PlistBuddy -c "Set :CFBundleIconFile icon.icns" "$plist"
	# Remove CFBundleIconName — prevents Asset Catalog from overriding our .icns
	/usr/libexec/PlistBuddy -c "Delete :CFBundleIconName" "$plist" 2>/dev/null || true
	# Add env vars via LSEnvironment (inherited by Ghostty's shell)
	# XDG_CONFIG_HOME points to per-project config to isolate each instance
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment dict" "$plist" 2>/dev/null || true
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_PROJECT_ID string ${safe_name}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_PROJECT_ID ${safe_name}" "$plist"
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_PROJECT_PATH string ${project_dir}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_PROJECT_PATH ${project_dir}" "$plist"
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:XDG_CONFIG_HOME string ${contents}/Resources/ghostty-config" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:XDG_CONFIG_HOME ${contents}/Resources/ghostty-config" "$plist"
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_SESSION_ID string ${session_id}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_SESSION_ID ${session_id}" "$plist"
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_USE_TERMINAL_NOTIFIER string 1" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_USE_TERMINAL_NOTIFIER 1" "$plist"
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_APP_NAME string ${name}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_APP_NAME ${name}" "$plist"
	# Authoritative backend marker for bundle_backend_for_path() in oste-spawn.sh.
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHL_MULTIPLEXER string ${multiplexer}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHL_MULTIPLEXER ${multiplexer}" "$plist"
	# Task identity tag — correlates this bundle to a specific orchestrator task.
	# Set by oste-spawn.sh via GHOSTTY_TASK_ID env var before invoking the launcher.
	if [[ -n "${GHOSTTY_TASK_ID:-}" ]]; then
		/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_TASK_ID string ${GHOSTTY_TASK_ID}" "$plist" 2>/dev/null ||
			/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_TASK_ID ${GHOSTTY_TASK_ID}" "$plist"
	fi

	# Register project-specific URL scheme for notification routing
	local url_scheme="commandcentral-${safe_name}"
	# Pass pre-computed URL scheme to Ghostty so it doesn't re-derive (avoids sanitization mismatch)
	/usr/libexec/PlistBuddy -c "Add :LSEnvironment:GHOSTTY_URL_SCHEME string ${url_scheme}" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :LSEnvironment:GHOSTTY_URL_SCHEME ${url_scheme}" "$plist"
	/usr/libexec/PlistBuddy -c "Add :CFBundleURLTypes array" "$plist" 2>/dev/null || true
	/usr/libexec/PlistBuddy -c "Add :CFBundleURLTypes:0 dict" "$plist"
	/usr/libexec/PlistBuddy -c "Add :CFBundleURLTypes:0:CFBundleURLName string ${url_scheme}" "$plist"
	/usr/libexec/PlistBuddy -c "Add :CFBundleURLTypes:0:CFBundleURLSchemes array" "$plist"
	/usr/libexec/PlistBuddy -c "Add :CFBundleURLTypes:0:CFBundleURLSchemes:0 string ${url_scheme}" "$plist"

	# ── Suppress Sparkle "Enable Automatic Updates?" first-launch prompt ──
	# Each per-project bundle has a unique CFBundleIdentifier, so Sparkle treats
	# each one as a separate app and shows the first-launch prompt. Setting these
	# Info.plist defaults disables auto-update entirely. Bundles should NOT
	# auto-update — they're derivatives of /Applications/Ghostty.app and would
	# lose their modifications. To pick up a new Ghostty version: just rebuild
	/usr/libexec/PlistBuddy -c "Add :SUEnableAutomaticChecks bool false" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :SUEnableAutomaticChecks false" "$plist"
	/usr/libexec/PlistBuddy -c "Add :SUAutomaticallyUpdate bool false" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :SUAutomaticallyUpdate false" "$plist"
	/usr/libexec/PlistBuddy -c "Add :SUHasLaunchedBefore bool true" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :SUHasLaunchedBefore true" "$plist"
	/usr/libexec/PlistBuddy -c "Add :SUSendProfileInfo bool false" "$plist" 2>/dev/null ||
		/usr/libexec/PlistBuddy -c "Set :SUSendProfileInfo false" "$plist"

	# Ad-hoc code sign the bundle BEFORE fileicon (order matters)
	if ! codesign --force --deep --sign - "$temp_app_path" 2>/dev/null; then
		echo "Warning: Code signing failed" >&2
	fi

	# Verify codesign worked
	if ! codesign --verify "$temp_app_path" 2>/dev/null; then
		echo "Error: Bundle codesign verification failed" >&2
		return 1
	fi

	# Set custom icon on the .app folder via fileicon (Finder-level override)
	# This modifies the .app directory's resource fork, not bundle contents
	if command -v fileicon >/dev/null 2>&1; then
		fileicon set "$temp_app_path" "${temp_resources}/icon.icns" >/dev/null 2>&1 || true
	fi

	# Clear Gatekeeper quarantine (allows opening despite fileicon modification)
	xattr -dr com.apple.quarantine "$temp_app_path" 2>/dev/null || true

	# Verify icon was set
	if [[ ! -f "${temp_resources}/icon.icns" ]]; then
		echo "Warning: icon.icns missing from bundle" >&2
	fi

	# Atomic move: remove existing and move temp to final location
	mkdir -p "$output_dir"
	# Ensure parent directory of app_path exists (in case name has slashes)
	mkdir -p "$(dirname "$app_path")"
	if [[ -d "$app_path" ]]; then
		trash "$app_path" 2>/dev/null || rm -rf "$app_path"
	fi

	if ! mv "$temp_app_path" "$app_path"; then
		echo "Error: Failed to move bundle to final location" >&2
		return 1
	fi

	# Register with Launch Services. This is best-effort: macOS can emit
	# Spotlight/LaunchServices scan errors for freshly created bundles even
	# when the app itself is valid and already on disk.
	local lsregister_err
	lsregister_err=$(mktemp)
	if ! /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "$app_path" \
		2>"$lsregister_err"; then
		echo "Warning: Launch Services registration failed for ${app_path}" >&2
		cat "$lsregister_err" >&2
	fi
	rm -f "$lsregister_err"

	# Refresh Dock to show custom icon immediately
	# Note: killall Dock would refresh icons but disrupts Cmd+Tab and user workflow.
	# The lsregister call above is sufficient — icons update on next Dock restart or login.
	# Users can run 'killall Dock' manually if they need immediate icon refresh.

	echo "$app_path"
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
	# Pre-pass: extract --multiplexer flag from anywhere in argv and export
	# MULTIPLEXER_OVERRIDE for create_bundle to consume. Removes the flag
	# from "$@" so subcommand parsing below doesn't have to handle it.
	local _argv=()
	local _i=0
	local _argc=$#
	while [[ $_i -lt $_argc ]]; do
		_i=$((_i + 1))
		case "$1" in
			--multiplexer)
				if [[ -z "${2:-}" ]]; then
					echo "Error: --multiplexer requires a value (tmux|zellij)" >&2
					exit 1
				fi
				export MULTIPLEXER_OVERRIDE="$2"
				shift 2
				_i=$((_i + 1))
				;;
			--multiplexer=*)
				export MULTIPLEXER_OVERRIDE="${1#--multiplexer=}"
				shift
				;;
			*)
				_argv+=("$1")
				shift
				;;
		esac
	done
	set -- "${_argv[@]+"${_argv[@]}"}"

	case "${1:-}" in
		--parse-icon)
			[[ -z "${2:-}" ]] && exit 1
			parse_icon "$2"
			;;
		--parse-name)
			[[ -z "${2:-}" ]] && exit 1
			parse_name "$2"
			;;
		--parse-multiplexer)
			[[ -z "${2:-}" ]] && exit 1
			parse_multiplexer "$2"
			;;
		--generate-icon)
			# --generate-icon EMOJI OUTPUT_PATH
			[[ -z "${2:-}" ]] && exit 1
			[[ -z "${3:-}" ]] && exit 1
			generate_emoji_icns "$2" "$3"
			;;
		--create-bundle)
			# --create-bundle DIR [--name NAME] [--output OUTPUT_DIR]
			[[ -z "${2:-}" ]] && exit 1
			local dir="$2"
			dir="$(cd "$dir" && pwd)"
			shift 2
			local output_dir="$PROJECTS_DIR"
			local name_override=""
			while [[ $# -gt 0 ]]; do
				case "$1" in
					--output)
						output_dir="${2:-}"
						[[ -z "$output_dir" ]] && {
							echo "Error: --output requires a value" >&2
							exit 1
						}
						shift 2
						;;
					--name)
						name_override="${2:-}"
						[[ -z "$name_override" ]] && {
							echo "Error: --name requires a value" >&2
							exit 1
						}
						shift 2
						;;
					*)
						shift
						;;
				esac
			done
			mkdir -p "$output_dir"
			local icon name
			icon=$(parse_icon "$dir")
			name="${name_override:-$(parse_name "$dir")}"
			create_bundle "$dir" "$name" "$icon" "$output_dir"
			;;
		--session-id)
			# Print the session ID for a project
			[[ -z "${2:-}" ]] && exit 1
			local dir="$2"
			dir="$(cd "$dir" && pwd)"
			local name
			name=$(parse_name "$dir")
			local safe
			safe=$(sanitize_for_bundle "$name")
			echo "agent-${safe}"
			;;
		--version | -v)
			echo "ghostty-launcher v${VERSION}"
			;;
		--help | -h)
			echo "Ghostty Launcher v${VERSION}"
			echo "Usage: launcher [OPTIONS] <project-dir>"
			echo ""
			echo "Options:"
			echo "  --multiplexer X        Force multiplexer (tmux|zellij). Overrides per-project setting."
			echo "                         Default: zellij. Set GHL_DEFAULT_MULTIPLEXER to change globally."
			echo "                         Or set commandCentral.terminal.multiplexer in .vscode/settings.json."
			echo "  --parse-icon DIR       Print emoji icon (settings → name → files → default)"
			echo "  --parse-name DIR       Print project name from settings"
			echo "  --parse-multiplexer DIR  Print multiplexer setting from .vscode/settings.json"
			echo "  --create-bundle DIR    Create .app bundle for DIR [--name NAME] [--output DIR]"
			echo "  --session-id DIR       Print session ID for DIR"
			echo "  --version              Print version"
			echo "  --help                 Show this help"
			;;
		*)
			local dir="${1:-$(pwd)}"
			dir="$(cd "$dir" && pwd)"

			mkdir -p "$PROJECTS_DIR"

			local icon name
			icon=$(parse_icon "$dir")
			name=$(parse_name "$dir")

			create_bundle "$dir" "$name" "$icon" "$PROJECTS_DIR"
			;;
	esac
}

main "$@"
